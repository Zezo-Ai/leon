{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "types": ["vite/client"],
    "allowImportingTsExtensions": true
  },
  "include": ["./src/**/*", "./vite.config.ts"],
  "exclude": ["./dist", "../node_modules"]
}
