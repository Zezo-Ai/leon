  "functions": {
    "transcribeToFile": {
      "description": "Transcribe audio to a file using faster-whisper.",
      "parameters": {
        "type": "object",
        "properties": {
          "inputPath": {
            "type": "string"
          },
          "outputPath": {
            "type": "string"
          },
          "device": {
            "type": "string"
          },
          "cpuThreads": {
            "type": "number"
          },
          "downloadRoot": {
            "type": "string"
          },
          "localFilesOnly": {
            "type": "boolean"
          }
        },
        "required": [
          "inputPath",
          "outputPath"
        ]
      }
    }
  }
