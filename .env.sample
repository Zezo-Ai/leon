# Main settings of Leon
# https://docs.getleon.ai/configuration

# Language currently used
LEON_LANG=en-US

# Server
LEON_HOST=http://localhost
LEON_PORT=1337

# Routing mode: smart | workflow | agent
LEON_ROUTING_MODE=smart

# Enable/disable LLM
LEON_LLM=true
# LLM provider
# Supported values: local | openrouter | openai | anthropic | moonshotai | huggingface | cerebras | groq
LEON_LLM_PROVIDER=local

# OpenRouter API key
LEON_OPENROUTER_API_KEY=
# OpenRouter model
LEON_OPENROUTER_MODEL=moonshotai/kimi-k2.5
# LEON_OPENROUTER_MODEL=openai/gpt-5.2-codex
# LEON_OPENROUTER_MODEL=anthropic/claude-opus-4.6
# LEON_OPENROUTER_MODEL=minimax/minimax-m2.5
# LEON_OPENROUTER_MODEL=z-ai/glm-5
# LEON_OPENROUTER_MODEL=qwen/qwen3-coder-next
# LEON_OPENROUTER_MODEL=xiaomi/mimo-v2-flash
# LEON_OPENROUTER_MODEL=qwen/qwen3-235b-a22b-2507
# LEON_OPENROUTER_MODEL=openai/gpt-oss-120b

# OpenAI API key
LEON_OPENAI_API_KEY=
# OpenAI model
LEON_OPENAI_MODEL=gpt-5.2-codex

# Anthropic API key
LEON_ANTHROPIC_API_KEY=
# Anthropic model
LEON_ANTHROPIC_MODEL=claude-opus-4-6
# LEON_ANTHROPIC_MODEL=claude-haiku-4-5

# Moonshot AI API key
LEON_MOONSHOTAI_API_KEY=
# Moonshot AI model
LEON_MOONSHOTAI_MODEL=kimi-k2.5

# HuggingFace API key
LEON_HUGGINGFACE_API_KEY=
# HuggingFace model
LEON_HUGGINGFACE_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# Cerebras API key
LEON_CEREBRAS_API_KEY=
# Cerebras model
LEON_CEREBRAS_MODEL=gpt-oss-120b

# Groq API key
LEON_GROQ_API_KEY=
# Groq model
LEON_GROQ_MODEL=llama-3.1-8b-instant

# Enable/disable Leon's wake word
LEON_WAKE_WORD=true

# Enable/disable Leon's speech-to-text
LEON_STT=true
# Speech-to-text provider
LEON_STT_PROVIDER=local

# Enable/disable Leon's text-to-speech
LEON_TTS=true
# Text-to-speech provider
LEON_TTS_PROVIDER=local

# Enable/disable LLM natural language generation
LEON_LLM_NLG=false
# Enable/disable LLM Action Recognition
# Can fallback to chit-chat if no action is recognized
LEON_LLM_ACTION_RECOGNITION=false

# Time zone (current one by default)
LEON_TIME_ZONE=

# Enable/disable after speech
LEON_AFTER_SPEECH=false

# Enable/disable skills to be available over HTTP
LEON_OVER_HTTP=true
# HTTP API key (use "npm run generate:http-api-key" to regenerate one)
LEON_HTTP_API_KEY=
# Language used for the HTTP API
LEON_HTTP_API_LANG=en-US

# Enable/disable telemetry
LEON_TELEMETRY=true

# Python TCP server
LEON_PY_TCP_SERVER_HOST=0.0.0.0
LEON_PY_TCP_SERVER_PORT=1342

# Path to the Pipfile
PIPENV_PIPFILE=tcp_server/src/Pipfile

# Path to the virtual env in .venv/
PIPENV_VENV_IN_PROJECT=true
