{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/bin",
    "rootDir": "../../",
    "baseUrl": ".",
    "paths": {
      "@@/*": ["../../*"],
      "@/*": ["../../server/src/*"],
      "@aurora/style.css": ["../../aurora/style.css"],
      "@aurora": ["../../aurora/dist/index.d.ts"],
      "@aurora/*": ["../../aurora/dist/*"],
      "@server/*": ["../../server/src/*"],
      "@bridge/*": ["./src/*"],
      "@sdk/*": ["./src/sdk/*"],
      "@tools/*": ["../../tools/*/src/nodejs/index.ts", "../../tools/*.ts"]
    },
    "exactOptionalPropertyTypes": false,
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
