{
  "extends": ["@tsconfig/strictest/tsconfig", "@tsconfig/node16/tsconfig"],
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ES2022",
    "moduleResolution": "Node",
    "module": "ESNext",
    "baseUrl": ".",
    "paths": {
      "@@/*": ["../*"],
      "@/*": ["../server/src/*"],
      "@bridge/*": ["../bridges/nodejs/src/*"],
      "@sdk/*": ["../bridges/nodejs/src/sdk/*"],
      "@tools/*": ["../tools/*/src/nodejs/index.ts", "../tools/*.ts"]
    },
    "resolveJsonModule": true
  }
}
